# Copy this file to secrets.toml and fill in your Supabase credentials.
# Alternatively, set SUPABASE_URL and SUPABASE_KEY as environment variables.
#
# If neither is configured the app falls back to an in-memory leaderboard
# (scores are lost on restart).

SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_KEY = "your-anon-or-service-key"
